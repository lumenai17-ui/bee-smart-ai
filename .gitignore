# Secrets & credentials
config/.env
vaults/
*.vault.json

# Runtime data
data/
*.sqlite
*.sqlite-wal
*.sqlite-shm

# Build output
dist/
node_modules/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
logs/

# Temp
tmp/
.tmp/
